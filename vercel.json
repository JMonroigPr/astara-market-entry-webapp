{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/bogota_astara_market_entry_siglas_definidas",
      "destination": "/bogota",
      "permanent": true
    },
    {
      "source": "/bogota_astara_market_entry_siglas_definidas.html",
      "destination": "/bogota",
      "permanent": true
    },
    {
      "source": "/lima_astara_market_entry_siglas_definidas",
      "destination": "/lima",
      "permanent": true
    },
    {
      "source": "/lima_astara_market_entry_siglas_definidas.html",
      "destination": "/lima",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
